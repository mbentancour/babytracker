# Copy this file to .env and fill in values as needed.
# .env is gitignored so secrets stay out of version control.

# ---- Database ----
# Default: SQLite (zero-config, no external database needed).
# The app creates a .db file inside DATA_DIR automatically.
#
# To use PostgreSQL instead, set DATABASE_URL to a postgres:// connection
# string and run with the Postgres compose override:
#   docker compose -f docker-compose.yml -f docker-compose.postgres.yml up
#
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=verify-full

# PostgreSQL credentials (only needed with the Postgres compose override).
# POSTGRES_USER=babytracker
# POSTGRES_PASSWORD=
# POSTGRES_DB=babytracker

# JWT signing secret. Leave empty — the app generates and persists a secure
# random secret in ${DATA_DIR}/.jwt_secret on first boot. Override only if you
# need the same secret across multiple replicas.
JWT_SECRET=

# Optional app settings
UNIT_SYSTEM=metric
DEMO_MODE=false
