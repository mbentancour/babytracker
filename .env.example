# Copy this file to .env and fill in production values before running
# docker compose up. .env is gitignored so secrets stay out of version control.

# PostgreSQL credentials (required for docker-compose).
# Generate a strong password: openssl rand -base64 32
POSTGRES_USER=babytracker
POSTGRES_PASSWORD=
POSTGRES_DB=babytracker

# Full DATABASE_URL override. Leave unset to build it from the POSTGRES_* vars
# above. For a networked/remote database, use sslmode=verify-full and include
# sslrootcert=.
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=verify-full

# JWT signing secret. Leave empty — the app generates and persists a secure
# random secret in ${DATA_DIR}/.jwt_secret on first boot. Override only if you
# need the same secret across multiple replicas.
JWT_SECRET=

# Optional app settings
UNIT_SYSTEM=metric
DEMO_MODE=false
